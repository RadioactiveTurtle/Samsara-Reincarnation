// Token

actor SamsaraHexenHasLMSPistolDisabled : Boolean {} // hack

// Parias (Reincarnation)

actor "Jade Wand" : SamsaraHexenWeapon
{
    Inventory.PickupMessage "Jade Wand"
    Weapon.SlotNumber 1
    Weapon.SelectionOrder 3600
    Weapon.Kickback 0
    Weapon.YAdjust 9
    Tag "Jade Wand"
    +WIMPY_WEAPON
    States
    {
      Spawn:
        H120 D -1
        stop

      Ready:
        H116 A 1 A_WeaponReady
        loop

      Deselect:
        H116 A 1 A_Lower
        loop

      Select:
        H116 A 1 A_Raise
        loop

      // Unpowered
      Fire:
        TNT1 A 0 A_JumpIfInventory("PowerSamsaraHexenWeaponLevel2",1,"FirePowered")
        TNT1 A 0 A_JumpIfInventory("SamsaraHasPermaWeaponLevel2",1,"FirePowered")
      FireUnpowered:
        H116 A 2
        H116 B 6 Bright Offset(0,48) A_GiveInventory("SamsaraHexenJadeWandAttackHandler")
        H116 A 5 Offset(0,40)
        TNT1 A 0 Offset(0,36) A_ReFire
        goto Ready

      // Powered
      FirePowered:
        H116 A 2
      FirePoweredLoop:
        H116 B 2 Bright Offset(0,48) A_GiveInventory("SamsaraHexenJadeWandPoweredAttackHandler")
        TNT1 A 0 A_JumpIfInventory("PowerSamsaraHexenWeaponLevel2",1,3)
        TNT1 A 0 A_JumpIfInventory("SamsaraHasPermaWeaponLevel2",1,2)
        TNT1 A 0 A_ClearReFire
        goto FirePoweredFinish
        TNT1 A 0 A_ReFire("FirePoweredLoop")
        goto FirePoweredFinish

      FirePoweredFinish:
        H116 A 2 Offset(0,40)
        TNT1 A 0 Offset(0,36) A_ReFire
        goto Ready
    }
}

actor SamsaraHexenJadeWandAttackHandler : Trigger
{
    States
    {
      // Attack stuff
      Pickup:
        TNT1 A 0 A_PlaySound("hexen/jadefire",CHAN_WEAPON)
        TNT1 A 0 A_JumpIfInventory("SPModeOn",1,"PickupCoop")
        TNT1 A 0 A_JumpIfInventory("CoopModeOn",1,"PickupCoop")
      PickupDM:
        TNT1 A 0 A_FireBullets(4,4,4,3,"SamsaraHexenJadePuff",FBF_NOFLASH)
        stop

      PickupCoop:
        TNT1 A 0 A_FireBullets(4,4,4,3,"SamsaraHexenJadePuffCoop",FBF_NOFLASH)
        stop
    }
}

actor SamsaraHexenJadeWandPoweredAttackHandler : Trigger
{
    States
    {
      // Attack stuff
      Pickup:
        TNT1 A 0 A_PlaySound("hexen/jadefire",CHAN_WEAPON)
        TNT1 A 0 A_JumpIfInventory("SPModeOn",1,"PickupCoop")
        TNT1 A 0 A_JumpIfInventory("CoopModeOn",1,"PickupCoop")
      PickupDM:
        TNT1 A 0 A_FireCustomMissile("SamsaraHexenJadeRay",0,false)
        stop

      PickupCoop:
        TNT1 A 0 A_FireCustomMissile("SamsaraHexenJadeRayCoop",0,false)
        stop
    }
}

actor SamsaraHexenJadePuff
{
    DamageType "Electric"
    RenderStyle "Add"
    Alpha 0.5
    Scale 0.5
    +NOBLOCKMAP
    +NOGRAVITY
    +PAINLESS
    +PUFFONACTORS
    States
    {
      Spawn:
        H116 IJ 2 Bright Light("CJADEWANDPUFF_X1")
        H116 K 2 Bright Light("CJADEWANDPUFF_X2")
        H116 L 2 Bright Light("CJADEWANDPUFF_X3")
        H116 M 2 Bright Light("CJADEWANDPUFF_X4")
        H116 N 2 Bright Light("CJADEWANDPUFF_X5")
        H116 O 2 Bright Light("CJADEWANDPUFF_X6")
        stop
    }
}

actor SamsaraHexenJadePuffCoop : SamsaraHexenJadePuff { +MTHRUSPECIES }

