Actor SquareMonster_Samsara : SamsaraMonsterFlemoid
{
	MONSTER
	Health 100
	Radius 20
	Height 48
	Speed 8
	FastSpeed 16
	MaxStepHeight 16
	Mass 1000
	PainChance 64
	BloodType "SquareBlood"
	PainSound "monster/pain"

	+NEVERRESPAWN
	+NOINFIGHTING

	MaxTargetRange 2048

	States
	{
		Death.Massacre:
			TNT1 A 0 ACS_NamedExecuteAlways("Samsara_KillCount", 0, 0)
			RIPM A 0 A_NoBlocking
			RIPM A 0 A_ChangeFlag("FLOATBOB", FALSE)
			RIPM A 0 A_ChangeFlag("NOGRAVITY", FALSE)
			RIPM A -1
			Stop
	}
}

